{
  "threshold": 100,
  "reporters": ["json", "console"],
  "output": "./coverage",
  "ignore": [
    "**/__tests__/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/node_modules/**",
    "**/.next/**",
    "**/coverage/**",
    "**/prisma/**"
  ],
  "absolute": false,
  "gitignore": true,
  "format": ["typescript", "tsx", "javascript", "jsx"]
}
